# Environment Variables for Tagesschau Summary App
# Copy this to .env.local and fill in the values

# Google GenAI API
GOOGLE_GENAI_API_KEY=your_google_api_key_here

# Resend API
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=your_email@example.com

# Vercel KV
KV_URL=your_kv_url_here
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token_here

# YouTube API (Optional if using RSS)
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_PLAYLIST_ID=PL4A2F331EE86DCC22
